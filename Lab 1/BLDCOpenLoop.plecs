          Type          Signal
          SrcComponent  "thm"
          SrcTerminal   1
          DstComponent  "Hall Sensor"
          DstTerminal   1
        }
        Connection {
          Type          Signal
          SrcComponent  "Hall Sensor"
          SrcTerminal   2
          DstComponent  "h"
          DstTerminal   1
        }
      }
